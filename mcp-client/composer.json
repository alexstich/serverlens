{
    "name": "devtools/serverlens-mcp",
    "description": "ServerLens MCP Proxy — local MCP server that connects to remote ServerLens via SSH",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "symfony/yaml": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "ServerLensMcp\\": "src/"
        }
    },
    "bin": ["bin/serverlens-mcp"],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
