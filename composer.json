{
    "name": "devtools/serverlens",
    "description": "ServerLens — Secure Read-Only Server Diagnostics MCP Server",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "react/http": "^1.9",
        "react/socket": "^1.15",
        "symfony/yaml": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "ServerLens\\": "src/"
        }
    },
    "bin": ["bin/serverlens"],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    }
}
